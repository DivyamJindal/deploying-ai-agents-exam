# SupportEscalator environment template.
# Copy to `.env` and fill in only the keys you actually need.
# The deterministic demo does NOT require any of these.

# Optional: swap the rule-based classifier/sentiment for a real LLM.
OPENAI_API_KEY=

# Default model — small, fast, cheap. Override if you want.
SUPPORT_ESCALATOR_MODEL=gpt-4.1-nano

# Optional: override the LangGraph thread namespace used by the checkpointer.
LANGGRAPH_THREAD_NAMESPACE=support_escalator
